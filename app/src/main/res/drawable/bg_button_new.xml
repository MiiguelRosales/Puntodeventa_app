<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="140"
                android:startColor="#4C4CB2"
                android:endColor="#4C4CB280" />
            <corners android:radius="8dp" />
            <stroke
                android:width="1dp"
                android:color="#6B6BD4" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="140"
                android:startColor="#4C4CB2"
                android:endColor="#4C4CB299" />
            <corners android:radius="8dp" />
            <stroke
                android:width="1dp"
                android:color="#3D3D99" />
        </shape>
    </item>
</selector>
