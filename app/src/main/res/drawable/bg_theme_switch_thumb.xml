<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <shape android:shape="oval">
            <size
                android:width="40dp"
                android:height="40dp" />
            <solid android:color="@color/switch_thumb_light" />
            <stroke
                android:width="2dp"
                android:color="@color/switch_thumb_light_stroke" />
        </shape>
    </item>

    <item>
        <shape android:shape="oval">
            <size
                android:width="40dp"
                android:height="40dp" />
            <solid android:color="@color/switch_thumb_dark" />
            <stroke
                android:width="2dp"
                android:color="@color/switch_thumb_dark_stroke" />
        </shape>
    </item>
</selector>