<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#1F2228" />
            <stroke
                android:width="2dp"
                android:color="#15171B" />
        </shape>
