<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:endColor="#005A9E"
                android:startColor="#1680D8" />
            <corners android:radius="999dp" />
            <stroke
                android:width="1dp"
                android:color="#B9DFFF" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:endColor="#0063B1"
                android:startColor="#1C8BE6" />
            <corners android:radius="999dp" />
            <stroke
                android:width="1dp"
                android:color="#B9DFFF" />
        </shape>
    </item>
</selector>
